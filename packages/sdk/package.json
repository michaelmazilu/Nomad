{
  "name": "@agent-passport/sdk",
  "version": "0.1.0",
  "description": "Protocol core: PDA derivation, canonical action-message encoding, Ed25519 sign/verify, Borsh passport decode, and permission evaluation. Runs in both browser and Node.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean --sourcemap",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@solana/web3.js": "^1.98.0",
    "tweetnacl": "^1.0.3"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
