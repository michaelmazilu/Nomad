# Copy this file to .env and fill in your key. .env is gitignored.
# The npm scripts load it via `tsx --env-file=.env`.

# Required: Anthropic API key used to call Haiku 4.5.
ANTHROPIC_API_KEY=

# Optional: model used for intent classification (default: claude-haiku-4-5).
ANTHROPIC_MODEL=claude-haiku-4-5

# Optional: port the proxy listens on (default: 8791).
PORT=8791
