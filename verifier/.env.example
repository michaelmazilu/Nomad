# Cluster is REQUIRED and first-class: a mismatch between where the passport was
# written and where the verifier reads is a silent `no_passport` deny.
CLUSTER=devnet

# RPC endpoint. Defaults per cluster; on mainnet-beta you MUST set a dedicated
# (non-public) URL — the public endpoint is heavily rate-limited.
# RPC_URL=https://api.devnet.solana.com

# Program ID (defaults to the SDK's built-in id).
# PROGRAM_ID=43MLqvfxob3RoxGGLMdqGUERCiGN5NKWJyuvvBSVjjgi

# Freshness / replay window in milliseconds (default 60000 = ±60s).
SKEW_MS=60000

# HTTP port for the reference server.
PORT=8787
