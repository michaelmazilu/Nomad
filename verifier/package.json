{
  "name": "@agent-passport/verifier",
  "version": "0.1.0",
  "private": true,
  "description": "Reference verification service: offline signature check + freshness + replay + on-chain read + permission check, fail-closed.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts src/server.ts --format esm --dts --clean --sourcemap",
    "start": "tsx src/server.ts",
    "dev": "tsx watch src/server.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agent-passport/sdk": "*",
    "@solana/web3.js": "^1.98.0",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
