{
  "name": "agent-passport",
  "private": true,
  "version": "0.1.0",
  "description": "Agent identity & permission passports on Solana",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "verifier",
    "extension",
    "connector"
  ],
  "scripts": {
    "dev:connector": "npm run dev -w @agent-passport/connector",
    "dev:extension": "npm run dev -w @agent-passport/extension",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:program": "anchor test",
    "demo": "tsx demo/e2e.ts",
    "grant": "tsx demo/grant.ts",
    "lint": "prettier --check .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.31.1",
    "@solana/web3.js": "^1.98.0",
    "@types/bn.js": "^5.1.5",
    "@types/chai": "^4.3.11",
    "@types/mocha": "^10.0.6",
    "@types/node": "^20.11.0",
    "chai": "^4.3.10",
    "mocha": "^10.3.0",
    "prettier": "^3.2.5",
    "tsx": "^4.19.2",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18"
  }
}
