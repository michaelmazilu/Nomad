# Jamazon storefront — server-side config for the /api/verify route, which reads
# agent passports from the Solana blockchain. These are SERVER-ONLY (no
# NEXT_PUBLIC_ prefix): the RPC call runs in the Route Handler, never the browser.
#
# Pin these to the cluster where the demo passport was actually created — a
# cluster mismatch silently reads an empty PDA and denies every order as
# no_passport.

# Cluster the storefront verifies against: devnet | localnet | mainnet-beta
NOMAD_CLUSTER=devnet

# RPC endpoint. STRONGLY RECOMMENDED for the demo: a dedicated devnet RPC URL.
# The public endpoint (https://api.devnet.solana.com) is rate-limited and the
# demo will be flaky on it. Leave blank to fall back to the SDK cluster default.
NOMAD_RPC_URL=

# Program ID. Optional — the SDK default already matches the deployed program.
NOMAD_PROGRAM_ID=43MLqvfxob3RoxGGLMdqGUERCiGN5NKWJyuvvBSVjjgi
